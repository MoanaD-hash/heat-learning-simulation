library(tidyverse)

## Simulate one block of the RL task with a given parameter configuration
rl.block = function(ap, an, b, N = 16, p1 = 0.7, p0 = 1-p1, v0 = 0.5) {
  choices = numeric(N)
  outcomes = numeric(N)
  values = matrix(nrow = 2, ncol = N)
  v = c(v0,v0) #v[1]: value of option 0; v[2]: value of option 1
  a = c(an,ap) #a[1]: negative LR; a[2]: positive LR
  p = c(p0,p1)
  for (i in seq_len(N)) {
    C = rbinom(1,1,plogis(b*(v[2]-v[1])))
    R = rbinom(1,1,p[C+1])
    choices[i] = C
    outcomes[i] = R
    values[,i] = v
    v[C+1] = v[C+1] + a[R+1]*(R-v[C+1])
  }
  list(choices = choices, outcomes = outcomes, values = values)
}

## Simulation parameters
nrep = 400;

a_steps = 40
b_vec = 2^seq(0,5)
pars = expand.grid(ap = seq(0,1,length.out = a_steps), an = seq(0,1,length.out = a_steps), b = b_vec)

pars$p_corr = NA

# Packages for parallel computing
library(future)
library(future.apply)

plan(multisession(workers = 8))

pars$p_corr = future_sapply(1:nrow(pars), function(i) replicate(nrep, rl.block(pars$ap[i], pars$an[i], pars$b[i])$choices[-1] %>%  mean) %>% mean, future.seed=TRUE)

