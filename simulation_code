### All of the next stuff is just to give a nicer (smoothed) figure

## Gaussian filter ##
gaussfilt.ll = function(x,sigma = 1, windowfact = 3) {
  
  kern = dnorm(seq(floor(-windowfact*sigma),ceiling(windowfact*sigma), by = 1), sd = sigma)
  hl = (length(kern)-1)/2
  x2 = c( rep(x[1],hl), x, rep(x[length(x)],hl))
  
  y = numeric(length(x))
  
  for (i in 1:length(x)) {
    x_cut = x2[i:(i + 2*hl)]
    y[i] = x_cut %*% kern;
  }
  return(y)
}

sigma = 1
windowfact = 3

pars_grouped = split(pars, pars$b)
p_matrices = lapply(pars_grouped, function(l) matrix(l$p_corr, nrow = length(unique(l$ap)), ncol = length(unique(l$an)))) %>% lapply(function(m) aws::kernsm(m)@y)
ps_matrices = lapply(p_matrices, function(m) array_tree(m,1) %>% 
                       lapply(function(x) gaussfilt.ll(x, sigma,windowfact)) %>% 
                       {do.call(rbind,.)} %>% 
                       array_tree(2) %>% 
                       lapply(function(x) gaussfilt.ll(x, sigma,windowfact)) %>% 
                       {do.call(cbind,.)}
                     )

for (i in 1:length(pars_grouped)) {
  pars_grouped[[i]]$ps = c(ps_matrices[[i]])
}

pars_smoothed = do.call(rbind, pars_grouped)

labels = paste0("beta = ", unique(pars_smoothed$b)); names(labels) = (unique(pars_smoothed$b))

ggplot(data =pars_smoothed, aes(x = ap, y = an, fill = ps*100)) + 
  geom_tile() + 
  facet_wrap(.~b, ncol = 2, labeller = as_labeller(labels)) +
  scale_fill_continuous(type = "viridis", name = "% Correct") +
  #scale_fill_gradient(low = "#000000", high = "#FFFFFF") +
  scale_x_continuous(name = "alpha +") + 
  scale_y_continuous(name = "alpha -")
