import numpy as np
import scipy.optimize as opt

# --- Define helper functions ---
def loglogistic(x):
    return -np.log(1 + np.exp(-x))

def logreg_negLL(beta, y, X):
    s1 = np.dot(y, loglogistic(X @ beta))
    s0 = np.dot(1 - y, loglogistic(-X @ beta))
    return -(s1 + s0)

